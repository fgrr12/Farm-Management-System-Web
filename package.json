{
	"name": "cattle",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"local": "vite --mode local-develop",
		"dev": "vite --mode develop",
		"prod": "vite --mode production",
		"build:develop": "tsc && vite build --mode develop",
		"build:production": "tsc && vite build --mode production",
		"preview": "vite preview",
		"test": "vitest",
		"lint": "biome check . --write",
		"format": "biome format --write .",
		"migrate": "biome migrate --write",
		"lint:check": "biome check .",
		"format:check": "biome format .",
		"i18n:scan": "i18next-scanner --config i18next-scanner.config.cjs",
		"i18n:format": "biome format public/locales --write",
		"i18n": "npm run i18n:scan && npm run i18n:format",
		"pwa:generate": "pwa-assets-generator --preset minimal-2023 --override"
	},
	"dependencies": {
		"@atlaskit/pragmatic-drag-and-drop": "^1.8.0",
		"@floating-ui/react": "^0.27.19",
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/query-async-storage-persister": "^5.99.1",
		"@tanstack/react-query": "^5.99.1",
		"@tanstack/react-query-persist-client": "^5.99.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.20",
		"firebase": "^12.12.0",
		"i18next": "^26.0.6",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^3.0.5",
		"react": "^19.2.5",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.72.1",
		"react-i18next": "^17.0.4",
		"react-router-dom": "7.14.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-query-devtools": "^5.99.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vitejs/plugin-react": "^6.0.1",
		"daisyui": "^5.5.19",
		"i18next-scanner": "^4.6.0",
		"jsdom": "^29.0.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"unocss": "^66.6.8",
		"vite": "^8.0.8",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.4",
		"workbox-core": "^7.4.0",
		"workbox-precaching": "^7.4.0",
		"workbox-routing": "^7.4.0",
		"workbox-window": "^7.4.0"
	}
